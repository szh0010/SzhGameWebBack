*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# === 虚拟环境 ===
# 忽略所有常见的虚拟环境文件夹名
venv/
env/
ENV/
.venv/
.env/

# === Django 特定文件 ===
# 数据库：忽略本地测试数据库
*.sqlite3
db.sqlite3

# 媒体文件：忽略用户上传的图片/头像（不进入代码库）
media/

# 静态文件：忽略 collectstatic 收集的结果
staticfiles/
static_root/

# 日志文件：忽略调试日志
*.log
logs/

# 密钥与本地配置：防止泄露 SECRET_KEY 或数据库密码
.env
local_settings.py

# === 前端 (Vue/Node) 特定文件 ===
# 如果你的前端代码也在这个目录下，这些必加
node_modules/
/dist/
/target/
.shorthand/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# === IDE 与 编辑器配置 ===
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# === 操作系统临时文件 ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === 数据库备份/导出 ===
*.sql
*.mysql
*.bak